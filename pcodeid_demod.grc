- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\n\n\nclass blk(gr.sync_block):  # other base classes\
      \ are basic_block, decim_block, interp_block\n    \"\"\"Phase-Coded Pulse Decoder\
      \ with Correlation Matching\"\"\"\n\n    def __init__(self, threshold=0.001,\
      \ pulselen=500e-6, bits=5, samp_rate=5e6):\n        \"\"\"arguments to this\
      \ function show up as parameters in GRC\"\"\"\n        gr.sync_block.__init__(\n\
      \            self,\n            name='Correlation Based Phase Code Decoder',\n\
      \            in_sig=[np.float32],  # bipolar baseband input\n            out_sig=[np.float32]\n\
      \        )\n        \n        # Parameters\n        self.threshold = threshold\n\
      \        self.pulselen = pulselen\n        self.bits = bits\n        self.samp_rate\
      \ = samp_rate\n        \n        # Timing calculations\n        self.spp = int(self.samp_rate\
      \ * self.pulselen)  # samples per pulse\n        self.spb = self.spp // self.bits\
      \  # samples per bit\n        self.dip_below_threshold = int(100e-6 * self.samp_rate)\n\
      \        \n        # State machine\n        self.in_pulse = False\n        self.pulse_num\
      \ = 0\n        self.last_decoded_bit = -1\n        self.samps_below_threshold\
      \ = 0\n        \n        # Ring buffer for delayed output\n        self.output_buffer\
      \ = np.zeros(self.spb, dtype=np.float32)\n        \n        # Pulse collection\
      \ for correlation\n        self.current_pulse_bits = []  # Store decoded bits\
      \ for current pulse\n        \n        # Reference sequences (data bits only,\
      \ no pilot)\n        # All 16 possible 4-bit sequences for testing\n       \
      \ self.reference_sequences = {\n            'SEQ_0000': np.array([0, 0, 0, 0]),\n\
      \            'SEQ_0001': np.array([0, 0, 0, 1]),\n            'SEQ_0010': np.array([0,\
      \ 0, 1, 0]),\n            'SEQ_0011': np.array([0, 0, 1, 1]),\n            'SEQ_0100':\
      \ np.array([0, 1, 0, 0]),\n            'SEQ_0101': np.array([0, 1, 0, 1]),\n\
      \            'SEQ_0110': np.array([0, 1, 1, 0]),\n            'SEQ_0111': np.array([0,\
      \ 1, 1, 1]),  # ICE\n            'SEQ_1000': np.array([1, 0, 0, 0]),\n     \
      \       'SEQ_1001': np.array([1, 0, 0, 1]),\n            'SEQ_1010': np.array([1,\
      \ 0, 1, 0]),\n            'SEQ_1011': np.array([1, 0, 1, 1]),\n            'SEQ_1100':\
      \ np.array([1, 1, 0, 0]),  # ICW\n            'SEQ_1101': np.array([1, 1, 0,\
      \ 1]),  # BKS\n            'SEQ_1110': np.array([1, 1, 1, 0]),\n           \
      \ 'SEQ_1111': np.array([1, 1, 1, 1])\n        }\n        \n        # Correlation\
      \ threshold (0.0 to 1.0, tune based on SNR)\n        self.correlation_threshold\
      \ = 0.7\n        \n        # Statistics\n        self.matched_pulses = {key:\
      \ 0 for key in self.reference_sequences.keys()}\n        self.unmatched_pulses\
      \ = 0\n\n    def correlate_pulse(self, pulse_bits):\n        \"\"\"\n      \
      \  Correlate decoded pulse bits against known sequences.\n        Returns (best_match_name,\
      \ correlation_score) or (None, 0) if below threshold.\n        \"\"\"\n    \
      \    if len(pulse_bits) != self.bits - 1:  # Should have bits-1 data bits\n\
      \            return None, 0.0\n        \n        pulse_array = np.array(pulse_bits)\n\
      \        best_match = None\n        best_score = -1.0\n        \n        for\
      \ seq_name, ref_seq in self.reference_sequences.items():\n            # Normalize\
      \ correlation: divide by sequence length\n            correlation = np.sum(pulse_array\
      \ == ref_seq) / len(ref_seq)\n            \n            if correlation > best_score:\n\
      \                best_score = correlation\n                best_match = seq_name\n\
      \        \n        # Check threshold\n        if best_score >= self.correlation_threshold:\n\
      \            return best_match, best_score\n        else:\n            return\
      \ None, best_score\n\n    def work(self, input_items, output_items):\n     \
      \   \"\"\"Decode phase-coded pulses with correlation matching\"\"\"\n      \
      \  bipolar_in = input_items[0]\n        out = output_items[0]\n        out[:]\
      \ = 0  # Default: no pulse\n        \n        for i in range(len(bipolar_in)):\n\
      \            mag = abs(bipolar_in[i])\n            \n            # Pulse detection\
      \ with hysteresis\n            if not self.in_pulse:\n                if mag\
      \ > self.threshold:\n                    self.in_pulse = True\n            \
      \        self.pulse_num += 1\n                    self.pulse_start_idx = i\n\
      \                    self.last_decoded_bit = -1\n                    self.output_buffer[:]\
      \ = 0\n                    self.current_pulse_bits = []  # Reset pulse collection\n\
      \                    print(f\"\\n[PULSE START] Pulse #{self.pulse_num} detected\"\
      )\n            else:\n                # Check for pulse end\n              \
      \  samples_in_pulse = i - self.pulse_start_idx\n                \n         \
      \       if mag < self.threshold:\n                    self.samps_below_threshold\
      \ += 1\n                    # Pulse ends after sustained low signal (hysteresis\
      \ only)\n                    if self.samps_below_threshold >= self.dip_below_threshold:\n\
      \                        # Pulse ended - perform correlation\n             \
      \           duration_us = (samples_in_pulse / self.samp_rate) * 1e6\n      \
      \                  match_name, match_score = self.correlate_pulse(self.current_pulse_bits)\n\
      \                        \n                        if match_name:\n        \
      \                    self.matched_pulses[match_name] += 1\n                \
      \            print(f\"[PULSE END - MATCHED] {match_name} (score: {match_score:.2f})\
      \ | \"\n                                  f\"{len(self.current_pulse_bits)}\
      \ bits | {duration_us:.1f}\xB5s\")\n                        else:\n        \
      \                    self.unmatched_pulses += 1\n                          \
      \  print(f\"[PULSE END - UNMATCHED] Best score: {match_score:.2f} | \"\n   \
      \                               f\"{len(self.current_pulse_bits)} bits | {duration_us:.1f}\xB5\
      s | \"\n                                  f\"bits={self.current_pulse_bits}\"\
      )\n                        \n                        # Print statistics\n  \
      \                      print(f\"Stats: {self.matched_pulses} | Unmatched: {self.unmatched_pulses}\"\
      )\n                        \n                        self.in_pulse = False\n\
      \                        self.samps_below_threshold = 0\n                  \
      \      continue\n                else:\n                    self.samps_below_threshold\
      \ = 0\n                \n                # Decode bits during pulse\n      \
      \          bit_index = samples_in_pulse // self.spb\n                \n    \
      \            if bit_index < self.bits and bit_index > self.last_decoded_bit:\n\
      \                    # Calculate stable region for this bit\n              \
      \      bit_start = bit_index * self.spb\n                    stable_start =\
      \ bit_start + int(0.2 * self.spb)\n                    \n                  \
      \  # For last bit, extend stable region to 95% to catch it before pulse ends\n\
      \                    if bit_index == self.bits - 1:\n                      \
      \  stable_end = bit_start + int(0.95 * self.spb)\n                    else:\n\
      \                        stable_end = bit_start + int(0.8 * self.spb)\n    \
      \                \n                    if stable_start <= samples_in_pulse <\
      \ stable_end:\n                        # Average bipolar signal in stable region\n\
      \                        local_start = max(0, i - 10)\n                    \
      \    avg_sign = np.sign(np.mean(bipolar_in[local_start:i+1]))\n            \
      \            \n                        if bit_index == 0:\n                \
      \            # Pilot bit - store reference\n                            self.pilot_sign\
      \ = avg_sign\n                            bit_value = 1.0  # Pilot always outputs\
      \ 1\n                            print(f\"Bit 0 (pilot): {bit_value}\")\n  \
      \                      else:\n                            # Data bit - compare\
      \ to pilot (non-differential)\n                            if avg_sign == self.pilot_sign:\n\
      \                                bit_value = 1.0  # Same phase as pilot\n  \
      \                              decoded_bit = 1\n                           \
      \ else:\n                                bit_value = -1.0  # Opposite phase\
      \ from pilot\n                                decoded_bit = 0\n            \
      \                \n                            self.current_pulse_bits.append(decoded_bit)\n\
      \                            print(f\"Bit {bit_index} (data): {bit_value} ->\
      \ {decoded_bit}\")\n                        \n                        self.output_buffer[:]\
      \ = bit_value\n                        self.last_decoded_bit = bit_index\n \
      \               \n                # Output from ring buffer\n              \
      \  out[i] = self.output_buffer[samples_in_pulse % self.spb]\n        \n    \
      \    return len(input_items[0])\n"
    affinity: ''
    alias: ''
    bits: '5'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    pulselen: pulselen
    samp_rate: samp_rate / decimation
    threshold: '0.003'
  states:
    _io_cache: ('Correlation Based Phase Code Decoder', 'blk', [('threshold', '0.001'),
      ('pulselen', '0.0005'), ('bits', '5'), ('samp_rate', '5000000.0')], [('0', 'float',
      1)], [('0', 'float', 1)], 'Phase-Coded Pulse Decoder with Correlation Matching',
      ['bits', 'pulselen', 'samp_rate', 'threshold'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [800, 64.0]
    rotation: 0
    state: disabled
